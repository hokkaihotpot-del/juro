# --- Database ---
DATABASE_URL=postgresql+asyncpg://juro:password@localhost:5432/juro_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- PHI Encryption (AES-256, 32 bytes base64-encoded) ---
PHI_ENCRYPTION_KEY=change-me-to-a-base64-encoded-32-byte-key

# --- Email (担当医レポート送信) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password
SMTP_TLS=true

# --- App ---
APP_ENV=development
APP_TITLE=JURO API
APP_VERSION=1.0.0
CORS_ORIGINS=["http://localhost:3000"]

# --- External Recipe Scraper ---
RECIPE_SCRAPER_USER_AGENT=JURO/1.0 (contact@example.com)
RECIPE_CACHE_TTL_SECONDS=604800

# --- Menu CSP ---
MENU_DUPLICATE_AVOID_DAYS=7
